# =============================================================================
# Vercel Serverless Environment Variables
# =============================================================================
# Copy this file to .env.local for local development (never commit .env.local).
# In production, set these in the Vercel dashboard → Settings → Environment Variables.
#
# NOTE: Variables prefixed with VITE_ are embedded in the browser bundle.
#       Do NOT put secrets in VITE_ variables.
# =============================================================================

# --- Admin dashboard (required) ----------------------------------------------
# Secret token used by the AdminDashboard UI to authenticate admin API calls.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=your_admin_token_here

# --- Base44 (required) -------------------------------------------------------
# Service-role token for server-side Base44 API calls (never expose to browser).
BASE44_SERVICE_TOKEN=your_base44_service_token_here

# Optional overrides — defaults are baked into api/_b44.js.
# B44_APP_ID=69b332a392004d139d4ba495
#
# Base44 API root URL.  The default is https://app.base44.com (correct host).
# Override this only if Base44 provides a different host for your region/plan.
# BASE44_BASE_URL=https://app.base44.com

# --- b44proxy shared secret (required) ---------------------------------------
# A random secret string sent by the frontend as X-B44-Proxy-Secret.
# Generate with: openssl rand -hex 32
B44_PROXY_SECRET=your_b44_proxy_secret_here

# --- RevenueCat (required) ---------------------------------------------------
# Server-side secret key for RevenueCat REST API calls.
REVENUECAT_SECRET_KEY=your_revenuecat_secret_key_here

# Authorization header value that RevenueCat sends with webhook POST requests.
# Set this in RevenueCat dashboard → Webhooks → Authorization header.
REVENUECAT_WEBHOOK_AUTH_HEADER=your_webhook_auth_value_here

# Optional: RevenueCat entitlement identifier used to determine active subscriptions.
# Defaults to "unfiltr by javier Pro" if not set.
# REVENUECAT_ENTITLEMENT_ID=unfiltr by javier Pro

# --- OpenAI (required for Vercel serverless chat/summarize/etc.) -------------
# Used server-side only — never in browser bundle (no VITE_ prefix).
OPENAI_API_KEY=your_openai_api_key_here

# --- AI guardrails (optional — safe defaults are baked in) -------------------
# Maximum total characters accepted across all messages in a single chat request.
# Requests that exceed this are rejected with a 400 before reaching OpenAI.
# AI_MAX_INPUT_CHARS=8000

# Hard cap on OpenAI completion tokens per request (applied on top of per-tier defaults).
# AI_MAX_OUTPUT_TOKENS=800

# Milliseconds before an in-flight OpenAI request is aborted (returns 504 to client).
# AI_REQUEST_TIMEOUT_MS=25000

# Maximum AI/chat requests allowed per user per minute (best-effort, per-instance).
# AI_MAX_RPM=10
